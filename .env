# ─────────────────────────────────────────────
# Application Grist Widget
# ─────────────────────────────────────────────
# Title displayed when sharing the SPA
VITE_GRIST_WIDGET_TITLE="Grist widget"
# Description used by social platforms when the SPA is shared
VITE_GRIST_WIDGET_DESCRIPTION="A Grist widget for rendering Markdown documents using the French Government Design System (DSFR)."

# ─────────────────────────────────────────────
# Open Graph metadata
# ─────────────────────────────────────────────
# Path to the default OG image displayed when sharing the SPA
VITE_GRIST_WIDGET_OPENGRAPH_IMAGE="/og-image.png"
# Canonical URL used for link previews
VITE_GRIST_WIDGET_OPENGRAPH_URL="https://your-app.example.com"
# Name of the site or application
VITE_GRIST_WIDGET_OPENGRAPH_SITE_NAME="Your App Name"
# Content type for Open Graph (e.g., website, article)
VITE_GRIST_WIDGET_OPENGRAPH_TYPE="website"
# Locale used for OG metadata (e.g., en_US, fr_FR)
VITE_GRIST_WIDGET_OPENGRAPH_LOCALE="fr_FR"

# ─────────────────────────────────────────────
# Build configuration
# ─────────────────────────────────────────────

# Defines the build strategy of the application.
# - STANDARD : Optimized assets splitting (multiple JS/CSS files).
# - SPA      : Single Page Application (everything inlined in one HTML file).
# To resolve the build strategy, it uses the following priority order:
#  1. CLI Shorthand flags (--spa, --standard)
#  2. Explicit CLI arguments (--VITE_BUILD_STRATEGY=...)
#  3. Vite environment variables (process.env.VITE_BUILD_STRATEGY)
#  4. and finally default fallback ("STANDARD")
VITE_BUILD_STRATEGY = "STANDARD"